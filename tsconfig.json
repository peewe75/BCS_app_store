{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2022"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ]
    },
    "strictNullChecks": true
  },
  "include": [
    "next-env.d.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "src/apps/**/*.ts",
    "src/apps/**/*.tsx",
    "src/components/Logo.tsx",
    "src/components/admin/AdminConsole.tsx",
    "src/components/auth/**/*.tsx",
    "src/components/apps/**/*.tsx",
    "src/components/site/**/*.tsx",
    "src/components/shells/**/*.tsx",
    "src/lib/**/*.ts",
    "src/pages/Login.tsx",
    "src/pages/Signup.tsx",
    "src/pages/UserDashboard.tsx",
    "src/pages/ForfApp.tsx",
    "src/pages/RavvedimentoApp.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
